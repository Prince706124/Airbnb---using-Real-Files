<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 font-sans">
    <%- include('../partials/header') %>
    <main class="mt-20 px-4 md:px-8 lg:px-12 py-12">
        <div class="max-w-7xl mx-auto">
            <!-- Header Section -->
            <div class="mb-12">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-6">
                    <div>
                        <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-3">
                            Welcome back, Host! 👋
                        </h1>
                        <p class="text-gray-600 text-lg">Manage your property listings and track your success</p>
                    </div>
                    <a href="/host/add-home" class="inline-flex items-center gap-3 bg-gradient-to-r from-red-500 to-pink-600 hover:from-red-600 hover:to-pink-700 text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-lg">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        Add New Home
                    </a>
                </div>
                <div class="w-24 h-1 bg-gradient-to-r from-red-500 to-pink-500 rounded-full"></div>
            </div>

            <!-- Stats Overview -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                <div class="bg-white rounded-xl shadow-lg p-6">
                    <div class="flex items-center gap-4">
                        <div class="bg-blue-100 p-3 rounded-full">
                            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="text-gray-600 text-sm font-medium">Total Listings</p>
                            <p class="text-3xl font-bold text-gray-800"><%= registeredHomes ? registeredHomes.length : 0 %></p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg p-6">
                    <div class="flex items-center gap-4">
                        <div class="bg-green-100 p-3 rounded-full">
                            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="text-gray-600 text-sm font-medium">Active Listings</p>
                            <p class="text-3xl font-bold text-gray-800"><%= registeredHomes ? registeredHomes.length : 0 %></p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg p-6">
                    <div class="flex items-center gap-4">
                        <div class="bg-purple-100 p-3 rounded-full">
                            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="text-gray-600 text-sm font-medium">Avg. Price/Night</p>
                            <p class="text-3xl font-bold text-gray-800">₹<%= registeredHomes && registeredHomes.length > 0 ? Math.round(registeredHomes.reduce((sum, home) => sum + home.price, 0) / registeredHomes.length) : 0 %></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Properties Section -->
            <% if (registeredHomes && registeredHomes.length > 0) { %>
                <div class="mb-8">
                    <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2">Your Properties</h2>
                    <p class="text-gray-600">Manage and monitor all your listed homes</p>
                </div>

                <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% registeredHomes.forEach(home=>{ %>
                        <li class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden">
                            <!-- Image Container -->
                            <div class="relative h-48 md:h-56 overflow-hidden bg-gray-200">
                                <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                                     src="<%= home.photo %>"
                                     alt="<%= home.Name %>">
                                <div class="absolute top-3 right-3 bg-green-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                    Active
                                </div>
                            </div>

                            <!-- Content Container -->
                            <div class="p-5 md:p-6">
                                <!-- Property Name -->
                                <h2 class="text-lg md:text-xl font-bold text-gray-800 mb-2 line-clamp-2 group-hover:text-red-500 transition-colors">
                                    <%= home.Name %>
                                </h2>

                                <!-- Details Grid -->
                                <div class="space-y-3 mb-5">
                                    <!-- Price -->
                                    <div class="flex items-center justify-between">
                                        <span class="text-gray-600 text-sm font-medium">Price per night</span>
                                        <span class="text-2xl font-bold text-red-500">
                                            ₹<%= home.price %>
                                        </span>
                                    </div>

                                    <!-- Rooms -->
                                    <div class="flex items-center gap-2">
                                        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M10.5 1.5H3.75A2.25 2.25 0 001.5 3.75v12.5A2.25 2.25 0 003.75 18.5h12.5a2.25 2.25 0 002.25-2.25V9.5m-15-4h4m-4 4h4m-4 4h4m8-12v4m0 4v4"></path>
                                        </svg>
                                        <span class="text-gray-700 font-medium"><%= home.rooms %> <%= home.rooms == 1 ? 'Room' : 'Rooms' %></span>
                                    </div>

                                    <!-- Food Type -->
                                    <div class="flex items-center gap-2">
                                        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"></path>
                                        </svg>
                                        <span class="text-gray-700 font-medium capitalize"><%= home.food %></span>
                                    </div>
                                </div>

                                <!-- Action Buttons -->
                                <div class="flex gap-3">
                                    <a href="/host/edit-home/<%= home._id %>?editing=true" class="flex-1 bg-gradient-to-r from-blue-500 to-cyan-600 hover:from-blue-600 hover:to-cyan-700 text-white font-bold py-3 px-4 rounded-lg transition-all duration-300 transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                        Edit
                                    </a>
                                    <form action="/host/delete-home/<%=home._id%>" method="post" class="flex-1">
                                        <button type="submit" onclick="return confirm('Are you sure you want to delete this property? This action cannot be undone.')" class="w-full bg-red-50 hover:bg-red-500 text-red-500 hover:text-white font-bold py-3 px-4 rounded-lg transition-all duration-300 border-2 border-red-500 hover:border-red-500 flex items-center justify-center gap-2">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                            </svg>
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <!-- Empty State -->
                <div class="text-center py-16">
                    <svg class="w-24 h-24 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    <h2 class="text-2xl font-bold text-gray-800 mb-2">No Properties Listed Yet</h2>
                    <p class="text-gray-600 mb-6">Start your hosting journey by adding your first property</p>
                    <a href="/host/add-home" class="inline-block bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-8 rounded-lg transition-colors duration-300">
                        Add Your First Home
                    </a>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>