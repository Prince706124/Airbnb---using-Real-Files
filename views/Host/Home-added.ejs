<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 font-sans">
    <%- include('../partials/header') %>
    <main class="mt-20 px-4 md:px-8 lg:px-12 py-12">
        <div class="max-w-2xl mx-auto text-center">
            <!-- Success Animation/Icon -->
            <div class="mb-8">
                <div class="relative mx-auto w-32 h-32 mb-6">
                    <!-- Success Checkmark Animation -->
                    <div class="absolute inset-0 bg-gradient-to-r from-green-400 to-emerald-500 rounded-full animate-pulse"></div>
                    <div class="relative flex items-center justify-center w-full h-full bg-white rounded-full shadow-lg">
                        <svg class="w-16 h-16 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <!-- Ripple effect -->
                    <div class="absolute inset-0 bg-green-400 rounded-full animate-ping opacity-20"></div>
                </div>
            </div>

            <!-- Success Message -->
            <div class="mb-8">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
                    Home Registered Successfully! 🎉
                </h1>
                <p class="text-xl text-gray-600 mb-6">
                    Your property has been added to our platform and is now available for bookings.
                </p>
                <div class="w-24 h-1 bg-gradient-to-r from-green-500 to-emerald-500 rounded-full mx-auto"></div>
            </div>

            <!-- Success Details Card -->
            <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10 mb-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <!-- Property Listed -->
                    <div class="text-center">
                        <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                            </svg>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-800 mb-2">Property Listed</h3>
                        <p class="text-gray-600">Your home is now live on our platform</p>
                    </div>

                    <!-- Ready for Bookings -->
                    <div class="text-center">
                        <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-800 mb-2">Ready for Bookings</h3>
                        <p class="text-gray-600">Guests can now discover and book your property</p>
                    </div>

                    <!-- Manage Listings -->
                    <div class="text-center">
                        <div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-800 mb-2">Manage Listings</h3>
                        <p class="text-gray-600">Edit or update your property anytime</p>
                    </div>
                </div>

                <!-- Next Steps -->
                <div class="border-t border-gray-200 pt-8">
                    <h3 class="text-xl font-semibold text-gray-800 mb-4">What's Next?</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
                        <div class="flex items-start gap-3">
                            <div class="bg-red-100 text-red-600 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">1</div>
                            <div>
                                <p class="font-medium text-gray-800">Monitor Bookings</p>
                                <p class="text-sm text-gray-600">Check your dashboard for new reservations</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="bg-red-100 text-red-600 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">2</div>
                            <div>
                                <p class="font-medium text-gray-800">Respond Quickly</p>
                                <p class="text-sm text-gray-600">Confirm bookings within 24 hours</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="bg-red-100 text-red-600 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">3</div>
                            <div>
                                <p class="font-medium text-gray-800">Prepare for Guests</p>
                                <p class="text-sm text-gray-600">Ensure your property is ready for check-in</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="bg-red-100 text-red-600 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">4</div>
                            <div>
                                <p class="font-medium text-gray-800">Earn Reviews</p>
                                <p class="text-sm text-gray-600">Great reviews help attract more guests</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/host/host-homelist" class="inline-flex items-center justify-center gap-3 bg-gradient-to-r from-red-500 to-pink-600 hover:from-red-600 hover:to-pink-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 transform hover:scale-105 active:scale-95 text-lg shadow-lg">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    View My Listings
                </a>
                <a href="/host/add-home" class="inline-flex items-center justify-center gap-3 bg-white hover:bg-gray-50 text-gray-800 font-bold py-4 px-8 rounded-xl transition-all duration-300 transform hover:scale-105 active:scale-95 text-lg shadow-lg border-2 border-gray-200">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add Another Home
                </a>
            </div>

            <!-- Back to Home -->
            <div class="mt-8">
                <a href="/" class="inline-flex items-center gap-2 text-gray-600 hover:text-red-500 transition-colors font-medium">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    Back to Home
                </a>
            </div>
        </div>
    </main>
</body>
</html>