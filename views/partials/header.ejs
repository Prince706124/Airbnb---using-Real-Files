<header class="bg-gradient-to-r from-red-500 to-pink-600 text-white shadow-lg fixed w-full top-0 z-50">
    <nav class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="flex justify-between items-center h-16 md:h-20">

            <!-- Logo/Brand -->
            <div class="flex items-center gap-3">
                <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
                    <div class="bg-white bg-opacity-20 p-2 rounded-lg">
                        <svg class="w-6 h-6 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                    </div>
                    <div class="hidden sm:block">
                        <h1 class="text-xl md:text-2xl font-bold">Airbnb</h1>
                        <p class="text-xs opacity-90">Find your perfect stay</p>
                    </div>
                </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden lg:flex items-center">
                <ul class="flex items-center space-x-2 text-sm font-medium">
                    <li>
                        <a href="/" class="<%= CurrentPage==='Home' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> py-3 px-4 rounded-xl transition-all duration-300 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                            </svg>
                            Home
                        </a>
                    </li>

                    <% if (isloggedIn) { %>
                        <% if(user && user.usertype === 'host') { %>
                            <li>
                                <a href="/host/add-home" class="<%= CurrentPage==='Add Home' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> py-3 px-4 rounded-xl transition-all duration-300 flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                    </svg>
                                    Add Home
                                </a>
                            </li>
                            <li>
                                <a href="/host/host-homelist" class="<%= CurrentPage==='Host Home list' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> py-3 px-4 rounded-xl transition-all duration-300 flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                                    </svg>
                                    My Listings
                                </a>
                            </li>
                        <% } else { %>
                            <li>
                                <a href="/home-list" class="<%= CurrentPage==='Home list' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> py-3 px-4 rounded-xl transition-all duration-300 flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                                    </svg>
                                    Browse Homes
                                </a>
                            </li>
                            <li>
                                <a href="/bookings" class="<%= CurrentPage==='Bookings' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> py-3 px-4 rounded-xl transition-all duration-300 flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                    My Bookings
                                </a>
                            </li>
                            <li>
                                <a href="/favourite-list" class="<%= CurrentPage==='Favourite' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> py-3 px-4 rounded-xl transition-all duration-300 flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                    </svg>
                                    Favourites
                                </a>
                            </li>
                        <% } %>
                    <% } %>
                </ul>
            </div>

            <!-- User Section -->
            <div class="flex items-center gap-3">
                <% if (isloggedIn) { %>
                    <!-- User Profile -->
                    <div class="hidden md:flex items-center gap-3 bg-white bg-opacity-10 rounded-xl px-4 py-2">
                        <div class="w-8 h-8 bg-white bg-opacity-20 rounded-full flex items-center justify-center">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                        </div>
                        <div class="hidden lg:block">
                            <p class="text-sm font-medium"><%= user ? user.firstName : 'User' %></p>
                            <p class="text-xs opacity-75 capitalize"><%= user ? user.usertype : 'Guest' %></p>
                        </div>
                    </div>

                    <!-- Logout Button -->
                    <form action="/logout" method="POST" class="flex">
                        <button type="submit" class="bg-white bg-opacity-20 hover:bg-opacity-30 text-white font-medium py-2 px-4 rounded-xl transition-all duration-300 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                            </svg>
                            <span class="hidden sm:inline">Logout</span>
                        </button>
                    </form>
                <% } else { %>
                    <!-- Auth Buttons -->
                    <div class="flex items-center gap-2">
                        <a href="/login" class="<%= CurrentPage==='Login' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> py-2 px-4 rounded-xl transition-all duration-300">
                            Login
                        </a>
                        <a href="/signup" class="<%= CurrentPage==='Signup' ? 'bg-white bg-opacity-20 text-white font-bold shadow-lg' : 'hover:bg-white hover:bg-opacity-10 text-white' %> bg-white bg-opacity-20 hover:bg-opacity-30 text-white font-medium py-2 px-4 rounded-xl transition-all duration-300">
                            Sign Up
                        </a>
                    </div>
                <% } %>

                <!-- Mobile Menu Button -->
                <button class="lg:hidden p-2 rounded-lg hover:bg-white hover:bg-opacity-10 transition-colors" id="mobile-menu-btn">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div class="lg:hidden hidden bg-white bg-opacity-95 backdrop-blur-sm border-t border-gray-200" id="mobile-menu">
            <div class="px-4 py-6 space-y-2">
                <a href="/" class="<%= CurrentPage==='Home' ? 'bg-red-500 text-white' : 'text-gray-700 hover:bg-gray-100' %> block py-3 px-4 rounded-lg transition-colors flex items-center gap-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    Home
                </a>

                <% if (isloggedIn) { %>
                    <% if(user && user.usertype === 'host') { %>
                        <a href="/host/add-home" class="<%= CurrentPage==='Add Home' ? 'bg-red-500 text-white' : 'text-gray-700 hover:bg-gray-100' %> block py-3 px-4 rounded-lg transition-colors flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                            </svg>
                            Add Home
                        </a>
                        <a href="/host/host-homelist" class="<%= CurrentPage==='Host Home list' ? 'bg-red-500 text-white' : 'text-gray-700 hover:bg-gray-100' %> block py-3 px-4 rounded-lg transition-colors flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                            </svg>
                            My Listings
                        </a>
                    <% } else { %>
                        <a href="/home-list" class="<%= CurrentPage==='Home list' ? 'bg-red-500 text-white' : 'text-gray-700 hover:bg-gray-100' %> block py-3 px-4 rounded-lg transition-colors flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                            </svg>
                            Browse Homes
                        </a>
                        <a href="/bookings" class="<%= CurrentPage==='Bookings' ? 'bg-red-500 text-white' : 'text-gray-700 hover:bg-gray-100' %> block py-3 px-4 rounded-lg transition-colors flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                            My Bookings
                        </a>
                        <a href="/favourite-list" class="<%= CurrentPage==='Favourite' ? 'bg-red-500 text-white' : 'text-gray-700 hover:bg-gray-100' %> block py-3 px-4 rounded-lg transition-colors flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                            </svg>
                            Favourites
                        </a>
                    <% } %>
                <% } %>
            </div>
        </div>
    </nav>
</header>

<script>
// Mobile menu toggle
document.getElementById('mobile-menu-btn').addEventListener('click', function() {
    document.getElementById('mobile-menu').classList.toggle('hidden');
});

// Close mobile menu when clicking outside
document.addEventListener('click', function(event) {
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');

    if (!mobileMenu.contains(event.target) && !mobileMenuBtn.contains(event.target)) {
        mobileMenu.classList.add('hidden');
    }
});
</script>