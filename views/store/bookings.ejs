<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 font-sans">
    <%- include('../partials/header') %>
    <main class="mt-20 px-4 md:px-8 lg:px-12 py-12">
        <div class="max-w-7xl mx-auto">
            <!-- Header Section -->
            <div class="mb-12">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-3">Your Bookings</h1>
                <p class="text-gray-600 text-lg">Manage your upcoming stays and booking history</p>
                <div class="w-24 h-1 bg-gradient-to-r from-red-500 to-pink-500 rounded-full mt-4"></div>
            </div>

            <!-- Bookings Grid -->
            <% if (registeredHomes && registeredHomes.length > 0) { %>
                <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% registeredHomes.forEach(home=>{ %>
                        <li class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden">
                            <!-- Image Container -->
                            <div class="relative h-48 md:h-56 overflow-hidden bg-gray-200">
                                <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                                     src="<%= home.photo %>"
                                     alt="<%= home.Name %>">
                                <div class="absolute top-3 right-3 bg-green-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                    Confirmed
                                </div>
                                <!-- Booking Status Badge -->
                                <div class="absolute top-3 left-3 bg-blue-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                    Upcoming
                                </div>
                            </div>

                            <!-- Content Container -->
                            <div class="p-5 md:p-6">
                                <!-- Property Name -->
                                <h2 class="text-lg md:text-xl font-bold text-gray-800 mb-2 line-clamp-2 group-hover:text-red-500 transition-colors">
                                    <%= home.Name %>
                                </h2>

                                <!-- Booking Details -->
                                <div class="space-y-3 mb-5">
                                    <!-- Check-in/Check-out -->
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                            </svg>
                                            <span class="text-gray-600 text-sm font-medium">Check-in</span>
                                        </div>
                                        <span class="text-gray-800 font-semibold">Dec 15, 2024</span>
                                    </div>

                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                            </svg>
                                            <span class="text-gray-600 text-sm font-medium">Check-out</span>
                                        </div>
                                        <span class="text-gray-800 font-semibold">Dec 20, 2024</span>
                                    </div>

                                    <!-- Price -->
                                    <div class="flex items-center justify-between pt-2 border-t border-gray-200">
                                        <span class="text-gray-600 text-sm font-medium">Total Price</span>
                                        <span class="text-2xl font-bold text-red-500">
                                            ₹<%= home.price * 5 %>
                                        </span>
                                    </div>

                                    <!-- Rooms -->
                                    <div class="flex items-center gap-2">
                                        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M10.5 1.5H3.75A2.25 2.25 0 001.5 3.75v12.5A2.25 2.25 0 003.75 18.5h12.5a2.25 2.25 0 002.25-2.25V9.5m-15-4h4m-4 4h4m-4 4h4m8-12v4m0 4v4"></path>
                                        </svg>
                                        <span class="text-gray-700 font-medium"><%= home.rooms %> <%= home.rooms == 1 ? 'Room' : 'Rooms' %></span>
                                    </div>

                                    <!-- Food Type -->
                                    <div class="flex items-center gap-2">
                                        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"></path>
                                        </svg>
                                        <span class="text-gray-700 font-medium capitalize"><%= home.food %></span>
                                    </div>
                                </div>

                                <!-- Action Buttons -->
                                <div class="flex gap-3">
                                    <button class="flex-1 bg-gradient-to-r from-blue-500 to-cyan-600 hover:from-blue-600 hover:to-cyan-700 text-white font-bold py-3 px-4 rounded-lg transition-all duration-300 transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                                        </svg>
                                        View Details
                                    </button>
                                    <button class="flex-1 bg-red-50 hover:bg-red-500 text-red-500 hover:text-white font-bold py-3 px-4 rounded-lg transition-all duration-300 border-2 border-red-500 hover:border-red-500 flex items-center justify-center gap-2">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                        </svg>
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <!-- Empty State -->
                <div class="text-center py-16">
                    <svg class="w-24 h-24 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                    <h2 class="text-2xl font-bold text-gray-800 mb-2">No Bookings Yet</h2>
                    <p class="text-gray-600 mb-6">You haven't made any bookings. Start exploring amazing homes!</p>
                    <a href="/home-list" class="inline-block bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-8 rounded-lg transition-colors duration-300">
                        Browse Homes
                    </a>
                </div>
            <% } %>
        </div>
    </main>

</body>
</html>