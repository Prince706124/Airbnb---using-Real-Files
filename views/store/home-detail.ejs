<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 font-sans">
    <%- include('../partials/header') %>
    <main class="mt-20 px-4 md:px-8 lg:px-12 py-12">
        <div class="max-w-6xl mx-auto">
            <!-- Back Button -->
            <div class="mb-8">
                <a href="/home-list" class="inline-flex items-center gap-2 text-gray-600 hover:text-red-500 transition-colors font-medium">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Back to Homes
                </a>
            </div>

            <!-- Property Header -->
            <div class="mb-8">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-3"><%= home.Name %></h1>
                <div class="w-24 h-1 bg-gradient-to-r from-red-500 to-pink-500 rounded-full"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                <!-- Image Section -->
                <div class="space-y-4">
                    <div class="relative h-96 md:h-[500px] overflow-hidden rounded-2xl shadow-2xl bg-gray-200">
                        <img class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                             src="<%= home.photo %>"
                             alt="<%= home.Name %>">
                        <div class="absolute top-4 right-4 bg-red-500 text-white px-4 py-2 rounded-full text-sm font-semibold shadow-lg">
                            Featured
                        </div>
                    </div>
                </div>

                <!-- Details Section -->
                <div class="space-y-8">
                    <!-- Price Card -->
                    <div class="bg-white rounded-xl shadow-lg p-6 md:p-8">
                        <div class="flex items-center justify-between mb-6">
                            <div>
                                <p class="text-gray-600 text-lg font-medium">Price per night</p>
                                <p class="text-4xl md:text-5xl font-bold text-red-500 mt-1">
                                    ₹<%= home.price %>
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="text-gray-600 text-sm">Total for 1 night</p>
                                <p class="text-2xl font-bold text-gray-800">₹<%= home.price %></p>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="space-y-4">
                            <button class="w-full bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 active:scale-95 flex items-center justify-center gap-3 text-lg">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16l4-4m0 0l4-4m-4 4l-4-4m4 4l4 4"></path>
                                </svg>
                                Book Now
                            </button>

                            <%- include('../partials/favourite') %>
                        </div>
                    </div>

                    <!-- Property Details -->
                    <div class="bg-white rounded-xl shadow-lg p-6 md:p-8">
                        <h2 class="text-2xl font-bold text-gray-800 mb-6">Property Details</h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Rooms -->
                            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg">
                                <div class="bg-red-100 p-3 rounded-full">
                                    <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M10.5 1.5H3.75A2.25 2.25 0 001.5 3.75v12.5A2.25 2.25 0 003.75 18.5h12.5a2.25 2.25 0 002.25-2.25V9.5m-15-4h4m-4 4h4m-4 4h4m8-12v4m0 4v4"></path>
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-gray-600 text-sm font-medium">Rooms</p>
                                    <p class="text-xl font-bold text-gray-800"><%= home.rooms %> <%= home.rooms == 1 ? 'Room' : 'Rooms' %></p>
                                </div>
                            </div>

                            <!-- Food Type -->
                            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg">
                                <div class="bg-red-100 p-3 rounded-full">
                                    <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-gray-600 text-sm font-medium">Food Type</p>
                                    <p class="text-xl font-bold text-gray-800 capitalize"><%= home.food %></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    <% if (home.description) { %>
                        <div class="bg-white rounded-xl shadow-lg p-6 md:p-8">
                            <h2 class="text-2xl font-bold text-gray-800 mb-4">Description</h2>
                            <p class="text-gray-700 leading-relaxed text-lg"><%= home.description %></p>
                        </div>
                    <% } %>

                    <!-- Host Information -->
                    <div class="bg-white rounded-xl shadow-lg p-6 md:p-8">
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">About the Host</h2>
                        <div class="flex items-center gap-4">
                            <div class="bg-gradient-to-r from-red-500 to-pink-500 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-lg">
                                H
                            </div>
                            <div>
                                <p class="text-lg font-semibold text-gray-800">Professional Host</p>
                                <p class="text-gray-600">Verified • 5+ years hosting experience</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

</body>
</html>